# Copy this file to ".env" for local use, or set these as environment variables on your host.

# Admin panel password (CHANGE THIS before going live)
VENOX_ADMIN_PASSWORD=change-this-strong-password

# Secret used to sign login sessions — make it a long random string
VENOX_SESSION_SECRET=put-a-long-random-string-here

# Port (most hosts set this automatically)
PORT=3000

# Only needed on hosts with ephemeral disks (Render/Railway). Point these at a
# mounted persistent disk so uploaded photos and content edits survive restarts.
# VENOX_DATA_DIR=/var/data
# VENOX_MEDIA_DIR=/var/data/media
